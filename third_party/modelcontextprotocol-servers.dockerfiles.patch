diff --git a/src/everything/Dockerfile b/src/everything/Dockerfile
index 6729298..5ffc42a 100644
--- a/src/everything/Dockerfile
+++ b/src/everything/Dockerfile
@@ -1,5 +1,11 @@
 FROM node:22.12-alpine AS builder
 
+ARG CUSTOM_CA_CERT=custom-ca.crt
+COPY ${CUSTOM_CA_CERT} /usr/local/share/ca-certificates/custom-ca.crt
+RUN apk add --no-cache ca-certificates && update-ca-certificates
+ENV NODE_EXTRA_CA_CERTS=/usr/local/share/ca-certificates/custom-ca.crt
+RUN npm config set cafile /usr/local/share/ca-certificates/custom-ca.crt
+
 COPY src/everything /app
 COPY tsconfig.json /tsconfig.json
 
@@ -9,6 +15,12 @@ RUN --mount=type=cache,target=/root/.npm npm install
 
 FROM node:22-alpine AS release
 
+ARG CUSTOM_CA_CERT=custom-ca.crt
+COPY ${CUSTOM_CA_CERT} /usr/local/share/ca-certificates/custom-ca.crt
+RUN apk add --no-cache ca-certificates && update-ca-certificates
+ENV NODE_EXTRA_CA_CERTS=/usr/local/share/ca-certificates/custom-ca.crt
+RUN npm config set cafile /usr/local/share/ca-certificates/custom-ca.crt
+
 WORKDIR /app
 
 COPY --from=builder /app/dist /app/dist
diff --git a/src/fetch/Dockerfile b/src/fetch/Dockerfile
index e81610c..a441108 100644
--- a/src/fetch/Dockerfile
+++ b/src/fetch/Dockerfile
@@ -1,6 +1,10 @@
 # Use a Python image with uv pre-installed
 FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS uv
 
+ARG CUSTOM_CA_CERT=custom-ca.crt
+COPY ${CUSTOM_CA_CERT} /usr/local/share/ca-certificates/custom-ca.crt
+RUN apt-get update && apt-get install -y ca-certificates && update-ca-certificates && rm -rf /var/lib/apt/lists/*
+
 # Install the project into `/app`
 WORKDIR /app
 
@@ -12,18 +16,22 @@ ENV UV_LINK_MODE=copy
 
 # Install the project's dependencies using the lockfile and settings
 RUN --mount=type=cache,target=/root/.cache/uv \
-    --mount=type=bind,source=uv.lock,target=uv.lock \
-    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
+    --mount=type=bind,source=src/fetch/uv.lock,target=uv.lock \
+    --mount=type=bind,source=src/fetch/pyproject.toml,target=pyproject.toml \
     uv sync --locked --no-install-project --no-dev --no-editable
 
 # Then, add the rest of the project source code and install it
 # Installing separately from its dependencies allows optimal layer caching
-ADD . /app
+ADD src/fetch /app
 RUN --mount=type=cache,target=/root/.cache/uv \
     uv sync --locked --no-dev --no-editable
 
 FROM python:3.12-slim-bookworm
 
+ARG CUSTOM_CA_CERT=custom-ca.crt
+COPY ${CUSTOM_CA_CERT} /usr/local/share/ca-certificates/custom-ca.crt
+RUN apt-get update && apt-get install -y ca-certificates && update-ca-certificates && rm -rf /var/lib/apt/lists/*
+
 WORKDIR /app
  
 COPY --from=uv /root/.local /root/.local
