# Compose-level deployment defaults for docker-compose.chat-client.yml
# Copy to `docker/.env` and export with:
#   set -a; source docker/.env; set +a
# Then run:
#   docker compose -f docker-compose.chat-client.yml up -d --build

# -------------------------------------------------------------------
# Chat-client runtime files/ports
# -------------------------------------------------------------------
CHAT_CLIENT_CONFIG_PATH=./docker/chat-client.env
CHAT_CLIENT_API_PORT=8090
CHAT_CLIENT_LOGS_DIR=./docker/runtime/chat-client/logs

# -------------------------------------------------------------------
# SQL-Agent MCP server (containerized sidecar)
# -------------------------------------------------------------------
SQL_AGENT_DB_URI=sqlite:////app/database/sql-agent.db
SQL_AGENT_LLM_PROVIDER=ollama
SQL_AGENT_LLM_BASE_URL=http://host.docker.internal:11434
SQL_AGENT_LLM_MODEL=qwen3:14b
SQL_AGENT_API_KEY=

SQL_AGENT_CACHE_DIR=./docker/runtime/sql-agent/cache
SQL_AGENT_DATABASE_DIR=./docker/runtime/sql-agent/database
SQL_AGENT_LOGS_DIR=./docker/runtime/sql-agent/logs
SQL_AGENT_CERTS_DIR=./docker/runtime/sql-agent/certificates
SQL_AGENT_QUERY_RESPONSES_DIR=./docker/runtime/sql-agent/query_responses

# -------------------------------------------------------------------
# File MCP server (containerized sidecar)
# -------------------------------------------------------------------
FILE_MCP_ENV_FILE_PATH=./docker/file-mcp.env
FILE_MCP_WORKSPACE_DIR=./docker/runtime/file-mcp/workspace
FILE_MCP_LOGS_DIR=./docker/runtime/file-mcp/logs
FILE_MCP_PROFILE=local
FILE_MCP_STORAGE_BACKEND=local
FILE_MCP_ROOT_PATH=/workspace
FILE_MCP_API_KEY_PRIMARY=change-me

# -------------------------------------------------------------------
# Search MCP server
# -------------------------------------------------------------------
# Search MCP is external in this compose setup.
# Configure endpoint and key in docker/chat-client.env.
