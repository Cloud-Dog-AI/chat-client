# File MCP server env file mounted at /workspace/env.base
# Copy to `docker/file-mcp.env` and adjust for your storage backend.

FILE_MCP_HTTP_HOST=0.0.0.0
FILE_MCP_HTTP_PORT=8000

FILE_MCP_PROFILE=local
FILE_MCP_STORAGE_BACKEND=local
FILE_MCP_ROOT_PATH=/workspace

FILE_MCP_AUTH_ENABLED=true
FILE_MCP_API_KEY_PRIMARY=change-me
FILE_MCP_AUTH_HEADER_NAME=Authorization
FILE_MCP_AUTH_HEADER_SCHEME=Bearer
