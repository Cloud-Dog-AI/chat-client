# Chat-client container profile
# Copy to `docker/chat-client.env` and edit for your deployment.

# Application
CLOUD_DOG__APP__NAME=cloud-dog-chat-client
CLOUD_DOG__APP__LOGFOLDER=/app/logs

# LLM
CLOUD_DOG__LLM__PROVIDER=ollama
CLOUD_DOG__LLM__BASE_URL=http://host.docker.internal:11434
CLOUD_DOG__LLM__MODEL=qwen3:14b
CLOUD_DOG__LLM__TIMEOUT_SECONDS=300
CLOUD_DOG__LLM__STREAM=false
CLOUD_DOG__LLM__TEMPERATURE=0.0
CLOUD_DOG__LLM__TOP_P=1.0
CLOUD_DOG__LLM__TOP_K=40
CLOUD_DOG__LLM__NUM_CTX=32768
CLOUD_DOG__LLM__MAX_TOKENS=4096

# Client API runtime
CLOUD_DOG__CLIENT_API__ENABLED=true
CLOUD_DOG__CLIENT_API__HOST=0.0.0.0
CLOUD_DOG__CLIENT_API__PORT=8090
CLOUD_DOG__CLIENT_API__API_KEY_HEADER=X-API-Key
CLOUD_DOG__CLIENT_API__ADMIN_API_KEY_HEADER=X-Admin-Key
CLOUD_DOG__CLIENT_API__ADMIN_API_KEY=
CLOUD_DOG__CLIENT_API__USER_HEADER=X-User

# Access mode
# No-auth mode: leave CLOUD_DOG__CLIENT_API__API_KEY empty
# API-key mode: set a non-empty value
CLOUD_DOG__CLIENT_API__API_KEY=

# MCP API behavior
CLOUD_DOG__MCP__API__REQUIRE_INITIALIZE=true
CLOUD_DOG__MCP__DEFAULTS__PROTOCOL_VERSION=2024-11-05

# MCP server 0: sql-agent mcp (HTTP JSON-RPC)
CLOUD_DOG__MCP__SERVERS__0__NAME=sql-agent-mcp
CLOUD_DOG__MCP__SERVERS__0__TRANSPORT=http_jsonrpc
CLOUD_DOG__MCP__SERVERS__0__BASE_URL=http://sql-agent-mcp:8081
CLOUD_DOG__MCP__SERVERS__0__MESSAGES_PATH=/messages
CLOUD_DOG__MCP__SERVERS__0__HEALTH_PATH=/health
CLOUD_DOG__MCP__SERVERS__0__TIMEOUT_SECONDS=300
CLOUD_DOG__MCP__SERVERS__0__API_KEY_HEADER=X-API-Key
CLOUD_DOG__MCP__SERVERS__0__API_KEY=
CLOUD_DOG__MCP__SERVERS__0__ASYNC_JOBS_ENABLED=true
CLOUD_DOG__MCP__SERVERS__0__ASYNC_JOBS_API_BASE_URL=http://sql-agent-api:8083
CLOUD_DOG__MCP__SERVERS__0__ASYNC_JOBS_STATUS_PATH=/jobs/{job_id}
CLOUD_DOG__MCP__SERVERS__0__ASYNC_JOBS_TIMEOUT_SECONDS=420
CLOUD_DOG__MCP__SERVERS__0__ASYNC_JOBS_POLL_INTERVAL_SECONDS=2.0

# MCP server 1: search mcp (Streamable HTTP)
CLOUD_DOG__MCP__SERVERS__1__NAME=search-mcp
CLOUD_DOG__MCP__SERVERS__1__TRANSPORT=streamable_http
CLOUD_DOG__MCP__SERVERS__1__BASE_URL=https://searchmcp.example.com
CLOUD_DOG__MCP__SERVERS__1__MCP_PATH=/mcp
CLOUD_DOG__MCP__SERVERS__1__HEALTH_PATH=/health
CLOUD_DOG__MCP__SERVERS__1__TIMEOUT_SECONDS=120
CLOUD_DOG__MCP__SERVERS__1__ENABLE_SSE=true
CLOUD_DOG__MCP__SERVERS__1__API_KEY_HEADER=X-API-Key
CLOUD_DOG__MCP__SERVERS__1__API_KEY=

# MCP server 2: file mcp (Streamable HTTP)
CLOUD_DOG__MCP__SERVERS__2__NAME=file-mcp
CLOUD_DOG__MCP__SERVERS__2__TRANSPORT=streamable_http
CLOUD_DOG__MCP__SERVERS__2__BASE_URL=http://file-mcp:8000
CLOUD_DOG__MCP__SERVERS__2__MCP_PATH=/mcp
CLOUD_DOG__MCP__SERVERS__2__HEALTH_PATH=/health
CLOUD_DOG__MCP__SERVERS__2__TIMEOUT_SECONDS=120
CLOUD_DOG__MCP__SERVERS__2__ENABLE_SSE=true
CLOUD_DOG__MCP__SERVERS__2__API_KEY_HEADER=Authorization
CLOUD_DOG__MCP__SERVERS__2__API_KEY=Bearer change-me

# MCP server 3: ExpertAgent Hungarian translator (HTTP JSON-RPC, optional)
CLOUD_DOG__MCP__SERVERS__3__NAME=expertagent0-hungarian
CLOUD_DOG__MCP__SERVERS__3__TRANSPORT=http_jsonrpc
CLOUD_DOG__MCP__SERVERS__3__BASE_URL=https://expertagent.example.com:8000
CLOUD_DOG__MCP__SERVERS__3__MESSAGES_PATH=/messages
CLOUD_DOG__MCP__SERVERS__3__MCP_PATH=/mcp
CLOUD_DOG__MCP__SERVERS__3__HEALTH_PATH=/mcp/health
CLOUD_DOG__MCP__SERVERS__3__TIMEOUT_SECONDS=60
CLOUD_DOG__MCP__SERVERS__3__READ_TIMEOUT_SECONDS=180
CLOUD_DOG__MCP__SERVERS__3__VERIFY_TLS=true
CLOUD_DOG__MCP__SERVERS__3__ACCEPT_HEADER=application/json
CLOUD_DOG__MCP__SERVERS__3__API_KEY_HEADER=X-API-Key
CLOUD_DOG__MCP__SERVERS__3__API_KEY=
CLOUD_DOG__MCP__SERVERS__3__ASSIST_ROLE=translator
CLOUD_DOG__MCP__SERVERS__3__ASSIST_USER_ID=1
CLOUD_DOG__MCP__SERVERS__3__ASSIST_EXPERT_CONFIG_ID=10
CLOUD_DOG__MCP__SERVERS__3__ASSIST_CHANNEL_ID=5
CLOUD_DOG__MCP__SERVERS__3__ASSIST_MAX_TOKENS=400

# Container entrypoint controls
CHAT_CLIENT_MODE=api
CHAT_CLIENT_ENV_FILE=/app/env
CHAT_CLIENT_API_HOST=0.0.0.0
CHAT_CLIENT_API_PORT=8090

# cloud_dog_db (W23A P3A)
CLOUD_DOG_DB__DIALECT=sqlite
CLOUD_DOG_DB__DATABASE=./database/chat-client.db
CLOUD_DOG_DB__SCHEMA=
CLOUD_DOG__DB__DIALECT=sqlite
CLOUD_DOG__DB__DATABASE=./database/chat-client.db
CLOUD_DOG__DB__SCHEMA=
