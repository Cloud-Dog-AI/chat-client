# Cloud-Dog chat-client example environment (no secrets)

# Core
CLOUD_DOG__APP__NAME=cloud-dog-chat-client
CLOUD_DOG__APP__LOGFOLDER=./logs

# API server
CLOUD_DOG__CLIENT_API__ENABLED=true
CLOUD_DOG__CLIENT_API__HOST=127.0.0.1
CLOUD_DOG__CLIENT_API__PORT=8090
CLOUD_DOG__CLIENT_API__API_KEY_HEADER=X-API-Key
CLOUD_DOG__CLIENT_API__API_KEY=
CLOUD_DOG__CLIENT_API__ADMIN_API_KEY_HEADER=X-Admin-Key
CLOUD_DOG__CLIENT_API__ADMIN_API_KEY=

# LLM
CLOUD_DOG__LLM__PROVIDER=ollama
CLOUD_DOG__LLM__BASE_URL=https://llm.example.com
CLOUD_DOG__LLM__MODEL=qwen3:14b
CLOUD_DOG__LLM__TIMEOUT_SECONDS=300
CLOUD_DOG__LLM__STREAM=true

# MCP default server example
CLOUD_DOG__MCP__SERVERS__0__NAME=search-mcp
CLOUD_DOG__MCP__SERVERS__0__TRANSPORT=streamable_http
CLOUD_DOG__MCP__SERVERS__0__BASE_URL=https://searchmcp.example.com
CLOUD_DOG__MCP__SERVERS__0__MCP_PATH=/mcp
CLOUD_DOG__MCP__SERVERS__0__HEALTH_PATH=/health

# Database (SQLite default)
CLOUD_DOG_DB__DIALECT=sqlite
CLOUD_DOG_DB__DATABASE=./database/chat-client.db
CLOUD_DOG_DB__SCHEMA=
