# ============================================================================
# CLOUD-DOG CHAT-CLIENT: PREPROD DOCKER ENV (ALL-4-IN-ONE)
# ============================================================================
#
# Purpose:
# - Runtime env for chat-client container with 4 MCP integrations:
#   search + file + expertagent-hungarian + sqlagent
# - Follows AT/local-docker topology and external connection contracts.
# - Uses vault-backed expressions for credentials and external service URIs.
#
# Usage:
# 1) set -a; source /opt/iac/Development/cloud-dog-ai/env-vault; set +a
# 2) cp env-docker-example docker/chat-client.env
# 3) start docker compose stack
#
# Notes:
# - This file is intentionally explicit (preprod handoff profile).
# - No fail-open ${vault... || ...} fallbacks are used.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
CLOUD_DOG__APP__NAME=cloud-dog-chat-client
CLOUD_DOG__APP__LOGFOLDER=/app/logs
CLOUD_DOG__LOG__LEVEL=INFO

# ---------------------------------------------------------------------------
# LLM
# ---------------------------------------------------------------------------
CLOUD_DOG__LLM__PROVIDER=ollama
CLOUD_DOG__LLM__BASE_URL=${vault.dev.models.ollama_qwen3_14b_llm1.base_url}
CLOUD_DOG__LLM__MODEL=qwen3:14b
CLOUD_DOG__LLM__TIMEOUT_SECONDS=300
CLOUD_DOG__LLM__STREAM=true
CLOUD_DOG__LLM__TEMPERATURE=0.0
CLOUD_DOG__LLM__TOP_P=1.0

# ---------------------------------------------------------------------------
# Client API
# ---------------------------------------------------------------------------
CLOUD_DOG__CLIENT_API__ENABLED=true
CLOUD_DOG__CLIENT_API__HOST=0.0.0.0
CLOUD_DOG__CLIENT_API__PORT=8090
CLOUD_DOG__CLIENT_API__BASE_URL=http://127.0.0.1:8090
CLOUD_DOG__CLIENT_API__REQUEST_TIMEOUT_SECONDS=300
CLOUD_DOG__CLIENT_API__UI_WAIT_TIMEOUT_SECONDS=300
CLOUD_DOG__CLIENT_API__REQUEST_ID_HEADER=X-Request-Id
CLOUD_DOG__CLIENT_API__API_KEY_HEADER=placeholder
CLOUD_DOG__CLIENT_API__API_KEY=${vault.dev.models.openai_qwen3_14b_openrouter_chatclient.api_key}
CLOUD_DOG__CLIENT_API__ADMIN_API_KEY_HEADER=placeholder
CLOUD_DOG__CLIENT_API__ADMIN_API_KEY=${vault.dev.models.openai_qwen3_14b_openrouter_chatclient.api_key}
CLOUD_DOG__CLIENT_API__USER_HEADER=X-User

# ---------------------------------------------------------------------------
# MCP API defaults
# ---------------------------------------------------------------------------
CLOUD_DOG__MCP__API__REQUIRE_INITIALIZE=false
CLOUD_DOG__MCP__API__STEP_TIMEOUT_SECONDS=180
CLOUD_DOG__MCP__DEFAULTS__PROTOCOL_VERSION=2024-11-05
CLOUD_DOG__MCP__DEFAULTS__MESSAGES_PATH=/messages
CLOUD_DOG__MCP__DEFAULTS__HEALTH_PATH=/health
CLOUD_DOG__MCP__DEFAULTS__SSE_PATH=/sse
CLOUD_DOG__MCP__DEFAULTS__TIMEOUT_SECONDS=300

# ---------------------------------------------------------------------------
# MCP Server 0: search-mcp (external)
# ---------------------------------------------------------------------------
CLOUD_DOG__MCP__SERVERS__0__NAME=search-mcp
CLOUD_DOG__MCP__SERVERS__0__TRANSPORT=streamable_http
CLOUD_DOG__MCP__SERVERS__0__BASE_URL=${vault.dev.services.searchmcp.uri}
CLOUD_DOG__MCP__SERVERS__0__MCP_PATH=/mcp
CLOUD_DOG__MCP__SERVERS__0__HEALTH_PATH=/health
CLOUD_DOG__MCP__SERVERS__0__ACCEPT_HEADER=application/json, text/event-stream
CLOUD_DOG__MCP__SERVERS__0__SSE_ACCEPT_HEADER=application/json, text/event-stream
CLOUD_DOG__MCP__SERVERS__0__TIMEOUT_SECONDS=180
CLOUD_DOG__MCP__SERVERS__0__VERIFY_TLS=true
CLOUD_DOG__MCP__SERVERS__0__ENABLE_SSE=false
CLOUD_DOG__MCP__SERVERS__0__API_KEY_HEADER=placeholder
CLOUD_DOG__MCP__SERVERS__0__API_KEY=${vault.dev.models.openai_qwen3_14b_openrouter_chatclient.api_key}
CLOUD_DOG__MCP__SERVERS__0__OUTPUT_FORMAT=json

# ---------------------------------------------------------------------------
# MCP Server 1: file-mcp (sidecar in docker stack)
# ---------------------------------------------------------------------------
CLOUD_DOG__MCP__SERVERS__1__NAME=file-mcp
CLOUD_DOG__MCP__SERVERS__1__TRANSPORT=streamable_http
CLOUD_DOG__MCP__SERVERS__1__BASE_URL=http://file-mcp:8000
CLOUD_DOG__MCP__SERVERS__1__MCP_PATH=/mcp
CLOUD_DOG__MCP__SERVERS__1__HEALTH_PATH=/health
CLOUD_DOG__MCP__SERVERS__1__ACCEPT_HEADER=application/json, text/event-stream
CLOUD_DOG__MCP__SERVERS__1__SSE_ACCEPT_HEADER=application/json, text/event-stream
CLOUD_DOG__MCP__SERVERS__1__TIMEOUT_SECONDS=180
CLOUD_DOG__MCP__SERVERS__1__VERIFY_TLS=false
CLOUD_DOG__MCP__SERVERS__1__ENABLE_SSE=false
CLOUD_DOG__MCP__SERVERS__1__API_KEY_HEADER=placeholder
CLOUD_DOG__MCP__SERVERS__1__AUTH_BEARER_TOKEN=${vault.dev.models.openai_qwen3_14b_openrouter_chatclient.api_key}
CLOUD_DOG__MCP__SERVERS__1__API_KEY=placeholder

# ---------------------------------------------------------------------------
# MCP Server 2: expertagent0-hungarian (external)
# ---------------------------------------------------------------------------
CLOUD_DOG__MCP__SERVERS__2__NAME=expertagent0-hungarian
CLOUD_DOG__MCP__SERVERS__2__TRANSPORT=http_jsonrpc
CLOUD_DOG__MCP__SERVERS__2__BASE_URL=https://expertagent.example.com:8000
CLOUD_DOG__MCP__SERVERS__2__MESSAGES_PATH=/messages
CLOUD_DOG__MCP__SERVERS__2__MCP_PATH=/mcp
CLOUD_DOG__MCP__SERVERS__2__HEALTH_PATH=/mcp/health
CLOUD_DOG__MCP__SERVERS__2__ACCEPT_HEADER=application/json
CLOUD_DOG__MCP__SERVERS__2__TIMEOUT_SECONDS=60
CLOUD_DOG__MCP__SERVERS__2__READ_TIMEOUT_SECONDS=180
CLOUD_DOG__MCP__SERVERS__2__VERIFY_TLS=true
CLOUD_DOG__MCP__SERVERS__2__API_KEY_HEADER=placeholder
CLOUD_DOG__MCP__SERVERS__2__API_KEY=${vault.dev.models.openai_qwen3_14b_openrouter_chatclient.api_key}
CLOUD_DOG__MCP__SERVERS__2__ASSIST_ROLE=translator
CLOUD_DOG__MCP__SERVERS__2__ASSIST_USER_ID=1
CLOUD_DOG__MCP__SERVERS__2__ASSIST_EXPERT_CONFIG_ID=10
CLOUD_DOG__MCP__SERVERS__2__ASSIST_CHANNEL_ID=5
CLOUD_DOG__MCP__SERVERS__2__ASSIST_MAX_TOKENS=placeholder
CLOUD_DOG__MCP__SERVERS__2__ASSIST_SESSION_TITLE=Hungarian translator MCP session

# ---------------------------------------------------------------------------
# MCP Server 3: sqlagent-mcp (external + async jobs)
# ---------------------------------------------------------------------------
CLOUD_DOG__MCP__SERVERS__3__NAME=sqlagent-mcp
CLOUD_DOG__MCP__SERVERS__3__TRANSPORT=http_jsonrpc
CLOUD_DOG__MCP__SERVERS__3__BASE_URL=${vault.dev.services.sqlagent0.mcp_url}
CLOUD_DOG__MCP__SERVERS__3__MESSAGES_PATH=/messages
CLOUD_DOG__MCP__SERVERS__3__HEALTH_PATH=/health
CLOUD_DOG__MCP__SERVERS__3__ACCEPT_HEADER=application/json
CLOUD_DOG__MCP__SERVERS__3__TIMEOUT_SECONDS=300
CLOUD_DOG__MCP__SERVERS__3__VERIFY_TLS=false
CLOUD_DOG__MCP__SERVERS__3__API_KEY_HEADER=placeholder
CLOUD_DOG__MCP__SERVERS__3__API_KEY=${vault.dev.models.openai_qwen3_14b_openrouter_chatclient.api_key}
CLOUD_DOG__MCP__SERVERS__3__OUTPUT_FORMAT=text
CLOUD_DOG__MCP__SERVERS__3__ASYNC_JOBS_ENABLED=true
CLOUD_DOG__MCP__SERVERS__3__ASYNC_JOBS_API_BASE_URL=${vault.dev.services.sqlagent0.api_url}
CLOUD_DOG__MCP__SERVERS__3__ASYNC_JOBS_STATUS_PATH=/jobs/{job_id}
CLOUD_DOG__MCP__SERVERS__3__ASYNC_JOBS_TIMEOUT_SECONDS=600
CLOUD_DOG__MCP__SERVERS__3__ASYNC_JOBS_POLL_INTERVAL_SECONDS=5

# ---------------------------------------------------------------------------
# Container entrypoint controls
# ---------------------------------------------------------------------------
CHAT_CLIENT_MODE=api
CHAT_CLIENT_ENV_FILE=/app/env
CHAT_CLIENT_API_HOST=0.0.0.0
CHAT_CLIENT_API_PORT=8090

# cloud_dog_db (W23A P3A)
CLOUD_DOG_DB__DIALECT=sqlite
CLOUD_DOG_DB__DATABASE=./database/chat-client.db
CLOUD_DOG_DB__SCHEMA=
CLOUD_DOG__DB__DIALECT=sqlite
CLOUD_DOG__DB__DATABASE=./database/chat-client.db
CLOUD_DOG__DB__SCHEMA=
